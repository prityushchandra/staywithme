# --- Database (Neon serverless Postgres) ---
# Use the POOLED connection string for the app (ends with -pooler), e.g.
# postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/mybnb?sslmode=require
DATABASE_URL=

# --- NextAuth / Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=
# Local: http://localhost:3000  | Vercel: your deployed URL
NEXTAUTH_URL=http://localhost:3000

# --- Google OAuth (optional for local; required for Google sign-in) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudinary (image storage) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Unsigned upload preset used by the listing image uploader
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=mybnb_listings

# --- Admin ---
# The seeded admin account email (gets isAdmin = true on seed)
ADMIN_EMAIL=admin@mybnb.local
ADMIN_PASSWORD=admin12345
